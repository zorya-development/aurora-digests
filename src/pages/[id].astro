---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

export async function getStaticPaths() {
  const digests = await getCollection("digests");
  return digests.map((digest) => ({
    params: { id: String(digest.id) },
    props: { digest },
  }));
}

const { digest } = Astro.props;
const { title, summary, sections, created_at } = digest.data;

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("ru-RU", {
    weekday: "long",
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function renderMarkdown(text: string): string {
  return text
    .replace(
      /\[([^\]]+)\]\(([^)]+)\)/g,
      '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>'
    )
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
    .replace(/\*([^*]+)\*/g, "<em>$1</em>");
}
---

<Base
  title={title || formatDate(created_at)}
  description={summary}
  showBack
  type="article"
  publishedAt={created_at}
>
  <article>
    <header class="dh">
      <p class="dh-date">{formatDate(created_at)}</p>
      <h1 class="dh-title">{title}</h1>
      {summary && <p class="dh-summary">{summary}</p>}
      <button class="share-btn" data-share-page>
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M11 2.5h2.5v2.5M13.5 2.5L8 8M7 3.5H3a1 1 0 0 0-1 1v8.5a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1V9"/>
        </svg>
        <span class="share-label">поделиться</span>
      </button>
    </header>

    {sections.map((section) => (
      <section class="dsec">
        <h2 class="dsec-title">{section.title}</h2>
        <ul class="items">
          {section.items.map((item) => (
            <li class="item">
              <h3 class="item-title">
                {item.article?.url ? (
                  <a href={item.article.url} target="_blank" rel="noopener noreferrer">
                    {item.title}
                  </a>
                ) : (
                  item.title
                )}
              </h3>
              <p class="item-body" set:html={renderMarkdown(item.body)} />
              {item.merged_sources.length > 0 && (
                <p class="item-also">
                  <span class="also-label">Источники:</span>
                  {item.merged_sources.map((s, i) => (
                    <span>
                      {i > 0 && ", "}
                      {s.url
                        ? <a href={s.url} target="_blank" rel="noopener noreferrer">{s.source_identifier ?? s.url}</a>
                        : s.source_identifier}
                    </span>
                  ))}
                </p>
              )}
              <button
                class="share-btn item-share"
                data-share-title={item.title}
              >
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M11 2.5h2.5v2.5M13.5 2.5L8 8M7 3.5H3a1 1 0 0 0-1 1v8.5a1 1 0 0 0 1 1h9a1 1 0 0 0 1-1V9"/>
                </svg>
                <span class="share-label">поделиться</span>
              </button>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </article>
</Base>

<script is:inline>
  document.querySelectorAll('.share-btn').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      const label = btn.querySelector('.share-label');
      const isPage = btn.hasAttribute('data-share-page');
      const url = isPage ? window.location.href : (btn.dataset.shareUrl || window.location.href);
      const title = isPage
        ? document.title
        : (btn.dataset.shareTitle || document.title);

      try {
        if (navigator.share) {
          await navigator.share({ title, url });
        } else {
          await navigator.clipboard.writeText(url);
          if (label) {
            const orig = label.textContent;
            label.textContent = '✓ скопировано';
            setTimeout(function () { label.textContent = orig; }, 1800);
          }
        }
      } catch (_) {}
    });
  });
</script>

<style is:global>
  /* Digest header */
  .dh {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .dh-date {
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
  }

  .dh-title {
    font-size: clamp(1.4rem, 3.5vw, 1.9rem);
    font-weight: 600;
    line-height: 1.3;
    color: #ece8e0;
    letter-spacing: -0.01em;
    margin-bottom: 0.9rem;
  }

  .dh-summary {
    font-size: 0.975rem;
    color: var(--text-content);
    line-height: 1.65;
    max-width: 56ch;
    margin-bottom: 0.9rem;
  }

  /* Share button */
  .share-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 0.12s;
  }

  .share-btn:hover {
    color: var(--text-muted);
  }

  .share-btn svg {
    width: 11px;
    height: 11px;
    flex-shrink: 0;
  }

  .item-share {
    margin-top: 0.6rem;
  }

  /* Sections */
  .dsec {
    margin-bottom: 2.5rem;
  }

  .dsec-title {
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* Items */
  .items {
    list-style: none;
  }

  .item {
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .item:last-child {
    border-bottom: none;
  }

  .item-title {
    font-size: 0.975rem;
    font-weight: 600;
    line-height: 1.45;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .item-title a {
    color: var(--text);
    text-decoration: none;
  }

  .item-title a:hover {
    color: var(--link-hover);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--link-hover) 50%, transparent);
    text-underline-offset: 3px;
  }

  .item-body {
    font-size: 0.9rem;
    color: var(--text-content);
    line-height: 1.75;
  }

  @media (max-width: 580px) {
    .item-body {
      font-size: 0.9rem;
      line-height: 1.45;
    }
  }

  .item-body a {
    color: var(--link);
  }

  .item-body a:hover {
    color: var(--link-hover);
  }

  .item-also {
    margin-top: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  .also-label {
    font-weight: 500;
    color: var(--text-muted);
    margin-right: 0.35rem;
  }

  .item-also a {
    color: var(--link);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--link) 40%, transparent);
    text-underline-offset: 3px;
  }

  .item-also a:hover {
    color: var(--link-hover);
  }
</style>
