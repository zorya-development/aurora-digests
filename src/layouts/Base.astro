---
interface Props {
  title: string;
  description?: string;
  showBack?: boolean;
  type?: "website" | "article";
  publishedAt?: string;
}

const {
  title,
  description = "Архив дайджестов по AI, LLM и self-hosting",
  showBack = false,
  type = "website",
  publishedAt,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://digests.zorya.dev");
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = `${title} · Silicon Ore`;

const jsonLd =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description,
        url: canonical,
        datePublished: publishedAt,
        publisher: {
          "@type": "Organization",
          name: "Silicon Ore",
          url: siteUrl.href,
        },
        mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
      }
    : {
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Silicon Ore",
        description,
        url: siteUrl.href,
      };
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Core SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Silicon Ore" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Silicon Ore" href="/rss.xml" />

    <!-- Analytics -->
    <script data-goatcounter="https://aurora-digests.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>

    <!-- Fonts -->
    <link
      href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="scroll-progress"></div>
    <div class="container">
      {showBack && (
        <header class="site-header">
          <a href="/" class="site-header-name">SILICON ORE</a>
          <a href="/rss.xml" class="header-rss" title="RSS">
            <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <circle cx="3" cy="13" r="1.5"/>
              <path d="M3 7.5A5.5 5.5 0 0 1 8.5 13H10A7 7 0 0 0 3 6v1.5z"/>
              <path d="M3 3A10 10 0 0 1 13 13h1.5A11.5 11.5 0 0 0 3 1.5V3z"/>
            </svg>
          </a>
        </header>
        <a href="/" class="back-btn">← все дайджесты</a>
      )}
      <slot />
      <footer class="site-footer">
        <a href="https://t.me/siliconore" target="_blank" rel="noopener noreferrer" class="footer-tg">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L8.32 14.617l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.828.942z"/>
          </svg>
          Читать в Telegram
        </a>
        <span class="footer-sep">·</span>
        <span class="footer-contact">
          контакт: <a href="https://t.me/a8h333" target="_blank" rel="noopener noreferrer">@a8h333</a>
        </span>
        <span class="footer-sep">·</span>
        <a href="/rss.xml" class="footer-rss">
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <circle cx="3" cy="13" r="1.5"/>
            <path d="M3 7.5A5.5 5.5 0 0 1 8.5 13H10A7 7 0 0 0 3 6v1.5z"/>
            <path d="M3 3A10 10 0 0 1 13 13h1.5A11.5 11.5 0 0 0 3 1.5V3z"/>
          </svg>
          RSS
        </a>
      </footer>
    </div>
  </body>
  <script>
    const bar = document.getElementById('scroll-progress')!;
    // Only show on digest detail pages (where back nav is shown)
    if (document.querySelector('.site-header')) {
      bar.classList.add('active');
      const update = () => {
        const scrolled = window.scrollY;
        const total = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = total > 0 ? (scrolled / total * 100) + '%' : '0%';
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
  </script>
</html>

<style is:global>
  :root {
    --bg:           #191919;
    --surface:      #222222;
    --border:       #2e2e2e;
    --text:         #d8d4cc;
    --text-content: #bababa;
    --text-muted:   #7a7a7a;
    --text-dim:     #555;
    --accent:       #d4952a;
    --link:         #6b9fd4;
    --link-hover:   #93bfee;
    --font:         'Rubik', 'Helvetica Neue', Arial, sans-serif;
    --mono:         'JetBrains Mono', 'Fira Mono', monospace;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html { font-size: 22px; }

  body {
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
    min-height: 100vh;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  @media (min-width: 900px) {
    .container {
      padding: 4rem 3rem 8rem;
    }
  }

  a {
    color: var(--link);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--link) 40%, transparent);
    text-underline-offset: 3px;
    transition: color 0.12s, text-decoration-color 0.12s;
  }

  a:hover {
    color: var(--link-hover);
    text-decoration-color: var(--link-hover);
  }

  .site-header {
    padding-bottom: 1.25rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-header-name {
    font-family: var(--mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color 0.12s;
  }

  .site-header-name:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .header-rss {
    color: var(--text-dim);
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: color 0.12s;
  }

  .header-rss:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .header-rss svg {
    width: 14px;
    height: 14px;
  }

  .back-btn {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    margin-bottom: 2.5rem;
    transition: color 0.12s;
  }

  .back-btn:hover {
    color: var(--text);
    text-decoration: none;
  }

  #scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 8px;
    width: 0%;
    background: var(--accent);
    z-index: 999;
    transition: width 0.1s linear;
    display: none;
  }

  #scroll-progress.active {
    display: block;
  }

  .site-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  .footer-tg {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.12s;
  }

  .footer-tg:hover {
    color: var(--text);
    text-decoration: none;
  }

  .footer-tg svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }

  .footer-sep {
    opacity: 0.4;
  }

  .footer-contact {
    color: var(--text-dim);
  }

  .footer-contact a {
    color: var(--text-muted);
    text-decoration: none;
  }

  .footer-contact a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .footer-rss {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.12s;
  }

  .footer-rss:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .footer-rss svg {
    width: 11px;
    height: 11px;
  }

  @media (max-width: 580px) {
    html { font-size: 18px; }
    :root { --text-content: #d0ccC4; }
    .container {
      padding: 1.5rem 1rem 4rem;
    }
  }
</style>
